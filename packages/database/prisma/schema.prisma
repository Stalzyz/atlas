datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  output   = "../generated-client"
  provider = "prisma-client-js"
  engineType = "library"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

enum OrderStatus {
  CREATED
  PAYMENT_PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  FAILED
  REFUNDED
}

enum OrderItemStatus {
  FULFILLED
  RETURNED
  EXCHANGED
}

enum ReturnExchangeType {
  RETURN
  EXCHANGE
}

enum SectionType {
  HERO
  FEATURED_COLLECTION
  FEATURE_GRID
  PRODUCT_GRID
  BANNER
  INSTAGRAM_FEED
  TESTIMONIALS
  TEXT_BLOCK
  LOOKBOOK
  EDITORIAL
  BRAND_STORY
  CATEGORIES_MOSAIC
  NEWSLETTER
  TRUST_BAR
  CATEGORY_STRIP
  AOV_BUNDLES
  STORY_BANNER
  DEAL_BANNER
  SOCIAL_PROOF
  SMART_GRID
  LOGO_CLOUD
  IMAGE_SCROLL
  CUSTOM_HTML
  LEGAL_PROSE
  ACCORDION_FAQ
  IMAGE_ROW
  PRODUCT_SCROLL
  ANNOUNCEMENT_MARQUEE
}

enum PageType {
  POLICY
  LANDING
  STORY
  BLANK
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OPERATIONS
  PRODUCT_MANAGER
  CMS_MANAGER
  MARKETING
  SUPPORT
  WAREHOUSE
  FINANCE
  ACCOUNTANT
  WHOLESALE_MANAGER
  CUSTOMER
}

model User {
  id             String         @id @default(cuid())
  clerkId        String?        @unique
  email          String         @unique
  phone          String?        @unique
  name           String?
  password       String?
  roleId         String?
  roleRef        Role?          @relation(fields: [roleId], references: [id])
  role           UserRole       @default(CUSTOMER)
  resetToken     String?        @unique
  resetExpires   DateTime?
  points         Int            @default(0)
  savedAddresses Json?          @default("[]")
  referralCode   String?        @unique
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  orders         Order[]
  reviews        Review[]
  WishlistItem   WishlistItem[]
  wallet         Wallet?
  referralsSent  Referral[]     @relation("Referrer")
  referralRecvd  Referral?      @relation("Referee")
  
  lastActiveAt   DateTime?
  interests      String[]       @default([])
  assignedOrders Order[]        @relation("AssignedOrders")
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  color       String?      @default("bg-gray-100 text-gray-600")
  permissions Permission[]
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          String   @id @default(cuid())
  action      String   @unique // e.g. "products:read", "orders:write"
  description String?
  roles       Role[]
  createdAt   DateTime @default(now())
}

model Product {
  id                String  @id @default(cuid())
  shopifyId         String? @unique
  handle            String  @unique
  title             String
  description       String?
  vendor            String?
  category          String?  // Category name (legacy: type)
  subCategory       String?
  brand             String?
  collection        String?
  productType       String?  // Clothing, Accessory, etc.
  gender            String?
  ageGroup          String?
  fabric            String?
  material          String?
  pattern           String?
  fitType           String?
  sleeveType        String?
  neckType          String?
  length            String?
  occasion          String?
  style             String?
  tags              String   @default("")
  searchKeywords    String?
  seoTitle          String?
  metaDescription   String?
  metaKeywords      String?
  published         Boolean  @default(false)
  hsnCode           String   @default("TEXTILE-00")
  lowStockThreshold Int      @default(10)
  status            String   @default("DRAFT")
  taxInclusive      Boolean  @default(true)
  taxRate           Decimal  @default(5.00)
  sizeGuideId       String?
  sizeGuide         SizeGuide? @relation(fields: [sizeGuideId], references: [id], onDelete: SetNull)

  variants Variant[]
  images   Image[]
  reviews  Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  collections  Collection[]   @relation("CollectionProducts")
  WishlistItem WishlistItem[]

  wholesaleOrderItems WholesaleOrderItem[]
}

model Variant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  sku            String?  @unique
  barcode        String?  @unique
  price          Decimal
  mrp            Decimal?
  sellingPrice   Decimal?
  offerPrice     Decimal?
  costPrice      Decimal?
  discountPercentage Decimal?
  inventory      Int      @default(0)
  currency       String   @default("INR")

  option1Name  String? // e.g. Size
  option1Value String? // e.g. XL
  option2Name  String? // e.g. Color
  option2Value String? // e.g. Red
  option3Name  String? // e.g. Secondary Color
  option3Value String? 

  images       Image[]            @relation("VariantImages")
  orderItems   OrderItem[]
  stockLogs    StockLog[]
  reservations StockReservation[]
  purchaseOrderItems PurchaseOrderItem[]
  wholesaleOrderItems WholesaleOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SizeGuide {
  id          String   @id @default(cuid())
  name        String   @unique
  htmlContent String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    Product[]
}

model Image {
  id       String  @id @default(cuid())
  url      String
  altText  String?
  position Int     @default(0)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  variantId String?
  variant   Variant? @relation("VariantImages", fields: [variantId], references: [id])

  reviewId String?
  review   Review? @relation("ReviewImages", fields: [reviewId], references: [id])

  createdAt DateTime @default(now())
}

model Collection {
  id          String  @id @default(cuid())
  shopifyId   String? @unique
  handle      String  @unique
  title       String
  description String?
  image       String?

  products Product[] @relation("CollectionProducts")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id                   String      @id @default(cuid())
  orderNumber          Int         @unique @default(autoincrement())
  formattedOrderNumber String?     @unique
  idempotencyKey       String?     @unique // 🛡️ Prevents double-creation
  userId               String?
  user            User?       @relation(fields: [userId], references: [id])

  status            OrderStatus @default(PAYMENT_PENDING)
  financialStatus   String?     @default("pending")   // paid, pending, refunded, voided
  fulfillmentStatus String?     @default("unfulfilled") // fulfilled, unfulfilled, partial

  // Financials
  totalAmount    Decimal
  subtotal       Decimal?
  total          Decimal?
  taxes          Decimal?  @default(0)
  shipping       Decimal?  @default(0)
  discountCode   String?
  discountAmount Decimal?
  walletCreditUsed Decimal? @default(0)
  currency       String?   @default("INR")

  // Customer
  customerName    String
  customerEmail   String
  customerPhone   String
  shippingAddress Json
  billingAddress  Json?

  // Payment
  paymentMethod   String?  // RAZORPAY, PHONEPE, COD
  paymentId       String?  @unique
  paymentIntentId String?  @unique
  paymentReference String?

  // Operations Control (Shopify-style)
  source          String    @default("web") // web, admin, pos, app
  riskLevel       String    @default("low") // low, medium, high
  tags            String[]  @default([])
  staffId         String?   // Assigned employee
  assignedStaff   User?     @relation("AssignedOrders", fields: [staffId], references: [id])
  internalNotes   String?

  // Fulfillment
  shippingMethod    String?
  trackingId        String?
  carrierName       String?
  estimatedDelivery DateTime?

  // Timestamps
  paidAt      DateTime?
  fulfilledAt DateTime?
  cancelledAt DateTime?

  // Metadata
  riskScore   Int?     @default(0)
  sourceIp    String?
  userAgent   String?
  notes       String?

  items        OrderItem[]
  fulfillments Fulfillment[]
  returns      OrderReturn[]
  activities   OrderActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  variantId String
  variant   Variant @relation(fields: [variantId], references: [id])

  quantity Int
  price    Decimal
  taxAmount Decimal @default(0)
  hsnCode  String? // Snapshot of product HSN at time of purchase

  status OrderItemStatus @default(FULFILLED)
  returnExchanges ReturnExchange[]
}

model ReturnExchange {
  id             String   @id @default(cuid())
  
  orderItemId    String
  orderItem      OrderItem @relation(fields: [orderItemId], references: [id])
  
  orderId        String
  type           ReturnExchangeType
  
  // If exchange, what variant did they swap to?
  newVariantId   String?  
  
  restocked      Boolean  @default(false)
  refundAmount   Decimal?
  refundMethod   String?  // "WALLET" or "SOURCE"
  notes          String?
  createdAt      DateTime @default(now())
}

model Review {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  rating   Int
  headline String?
  content  String
  approved Boolean @default(false)

  images Image[] @relation("ReviewImages")

  createdAt DateTime @default(now())
}

model Page {
  id              String     @id @default(cuid())
  handle          String     @unique // The URL slug
  title           String
  type            PageType   @default(LANDING)
  status          PageStatus @default(DRAFT)
  
  // SEO Hardening
  metaTitle       String?
  metaDescription String?
  ogImage         String?

  sections Section[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?
}

model Section {
  id     String @id @default(cuid())
  pageId String
  page   Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)

  type    SectionType
  order   Int         @default(0)
  content Json // Text, Links, Media mapping
  style   Json? // Visual design specs (padding, colors)
  settings Json? // Behavior specs (animation, alignment)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ThemeSettings {
  id             String   @id @default("global")
  storeName      String   @default("Atlas")
  logoLight      String?
  logoDark       String?
  faviconLight   String?
  faviconDark    String?
  defaultThemeMode String  @default("LIGHT") // LIGHT, DARK
  
  primaryColor   String   @default("#701A31")
  secondaryColor String   @default("#F4F1ED")
  fontHeading    String   @default("serif")
  fontBody       String   @default("sans")
  buttonRadius   String   @default("0.5rem")
  
  customGlobalCss  String?
  customFooterHtml String?
  
  config         Json?    // Catch-all for additional tokens (light_bg, dark_bg, etc.)
  footerConfig   Json?    // Dynamic layout, menus, and branding for footer
  
  updatedAt      DateTime @updatedAt
}

model ThemePreset {
  id           String   @id @default(cuid())
  name         String
  description  String?
  previewImage String?
  config       Json     // Contains theme: { ... } and sections: [ ... ]
  
  isActive     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Media {
  id        String   @id @default(cuid())
  filename  String
  url       String
  type      String   @default("image") // image, video
  size      Int?
  mimeType  String?
  folder    String   @default("All")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WishlistItem {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

// ─── WHOLESALE MODULE ─────────────────────────────────────────────────────────

enum RetailerTier {
  SILVER
  GOLD
  PLATINUM
  CUSTOM
}

enum RetailerStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

model Retailer {
  id             String         @id @default(cuid())
  clerkId        String?        @unique
  businessName   String
  contactName    String
  email          String         @unique
  phone          String
  gstNumber      String?
  address        String?
  city           String?
  state          String?
  tier           RetailerTier   @default(SILVER)
  status         RetailerStatus @default(PENDING)
  creditLimit    Decimal?
  creditTermDays Int?           @default(0)
  notes          String?

  priceListId String?
  priceList   PriceList? @relation(fields: [priceListId], references: [id])

  orders WholesaleOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PriceList {
  id              String   @id @default(cuid())
  name            String   @unique
  discountPercent Decimal
  moqPerSku       Int      @default(1)
  moqPerOrder     Decimal?

  retailers Retailer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WholesaleOrder {
  id         String   @id @default(cuid())
  retailerId String
  retailer   Retailer @relation(fields: [retailerId], references: [id])

  status      String  @default("DRAFT")
  isPublished Boolean @default(false)
  totalAmount Decimal @default(0)
  advancePaid Decimal @default(0)
  notes       String?
  emailSentAt DateTime?

  items WholesaleOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WholesaleOrderItem {
  id      String         @id @default(cuid())
  orderId String
  order   WholesaleOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  variantId String
  variant   Variant @relation(fields: [variantId], references: [id])

  quantity           Int
  unitMrp            Decimal
  unitWholesalePrice Decimal
  totalPrice         Decimal
  hsnCode            String?
}

// ─── MARKETING MODULE ─────────────────────────────────────────────────────────

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model Discount {
  id    String       @id @default(cuid())
  code  String       @unique
  type  DiscountType
  value Decimal

  minOrderValue Decimal?
  maxDiscount   Decimal?
  usageLimit    Int?
  usageLimitPerUser Int @default(1)
  usedCount     Int      @default(0)

  minQuantity   Int?     @default(1)
  autoApply     Boolean  @default(false)

  startDate DateTime?
  endDate   DateTime?
  
  applicableProducts   String[] @default([])
  applicableCategories String[] @default([])
  isStackable         Boolean  @default(false)

  isActive  Boolean   @default(true)
  expiresAt DateTime?

  usages    DiscountUsage[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DiscountUsage {
  id         String   @id @default(cuid())
  discountId String
  discount   Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  userId     String
  orderId    String
  createdAt  DateTime @default(now())
}

// ─── GLOBAL SETTINGS ──────────────────────────────────────────────────────────

model StoreSettings {
  id              String  @id @default("global") // We only want one record
  storeName       String  @default("Atlas")
  logoUrl         String?
  supportEmail    String?
  supportPhone    String?
  tagline         String? @default("Luxury ethnic wear crafted for the moments that matter most.")
  footerCopyright String? @default("All rights reserved.")

  instagramUrl String?
  facebookUrl  String?
  twitterUrl   String?
  pinterestUrl String?
  youtubeUrl   String?

  // AI & Assistant Settings
  openAiApiKey       String?

  // WhatsApp Autopilot (Grafty.pro — Legacy)
  whatsappApiUrl String? @default("https://api.grafty.pro/v1")
  whatsappApiKey String?
  whatsappAppId  String?

  // Grafty Event Integration (The "Handshake" V1)
  graftyApiUrl     String? @default("https://grafty.pro/api/integrations/v1/event")
  graftyApiKey     String?
  graftyWorkspaceId String?

  // External Tracking & APIs
  googleAnalyticsId         String?
  googleSearchConsoleKey    String?
  whatsappPhoneNumberId     String?
  whatsappBusinessAccountId String?

  // SMTP Settings
  smtpHost        String?
  smtpPort        Int?     @default(587)
  smtpUser        String?
  smtpPass        String?
  smtpSecure      Boolean  @default(false)

  // Financial & Tax Settings (for Wholesale)
  bankName        String?  @default("HDFC Bank")
  bankBranch      String?
  accountNumber   String?
  accountName     String?
  ifscCode        String?
  gstNumber       String? // Business GSTIN
  businessAddress String?
  businessState   String?  @default("Tamil Nadu")
  defaultGstRate  Decimal? @default(5.00)

  // Payment Gateway Configurations
  activePaymentGateway String? @default("RAZORPAY") // RAZORPAY, PHONEPE, BOTH
  razorpayKeyId       String?

  // Return Policy Settings
  returnWindowDays    Int      @default(7)
  requireImagesForReturn Boolean @default(true)
  autoApproveLowValue Boolean  @default(false)
  razorpayKeySecret   String?
  razorpayWebhookSecret String?
  phonepeMerchantId   String?
  phonepeMerchantUserId String?
  phonepeSaltKey      String?
  phonepeSaltIndex    String? @default("1")

  // Marketing & Tracking
  metaPixelId     String?
  metaCapiToken   String?

  // Security & 2FA
  googleAuthSecret String?
  googleClientId   String?
  googleClientSecret String?
  aiAssistantEnabled Boolean @default(true)
  customGlobalCss  String?
  customHeadHtml   String?
  customFooterHtml String?

  // Marketing & Growth Controls
  referralRewardPercent   Decimal? @default(10.00)
  welcomeDiscountPercent  Decimal? @default(10.00)
  maxCreditUsagePercent   Decimal? @default(50.00)
  
  // Loyalty & Points
  loyaltyMinOrderValue    Decimal? @default(2000.00)
  loyaltyPointsRate       Decimal? @default(1.00) // E.g., 1 point per 100 Rs spent

  // Shipping & Logistics (Prisma 7 Upgrade Fix)
  delhiveryToken          String?
  delhiveryPickupLocation String?
  shiprocketEmail         String?
  shiprocketPassword      String?
  shiprocketPickupLocation String?
  customShippingRules     Json?   @default("[]") // Format: [{ collection: string, minQty: number, cost: number }]

  // Order Formatting
  orderPrefix             String?
  orderSuffix             String?

  updatedAt DateTime @updatedAt
}

enum LedgerType {
  SALE
  PURCHASE
  PAYMENT
  REFUND
}

model LedgerEntry {
  id          String   @id @default(cuid())
  type        LedgerType
  amount      Decimal
  referenceId String?  // Order ID, Purchase Order ID, or Invoice ID
  partyName   String?  // Customer or Supplier Name
  status      String   @default("COMPLETED")
  notes       String?
  isDraft     Boolean  @default(false)
  
  taxableValue Decimal?
  cgst         Decimal?
  sgst         Decimal?
  igst         Decimal?
  totalTax     Decimal?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PaymentIntent {
  id              String   @id @default(cuid())
  providerOrderId String   @unique
  gateway         String   // RAZORPAY, PHONEPE
  amount          Decimal
  status          String   @default("PENDING") // PENDING, SUCCESS, FAILED
  customerInfo    Json
  metadata        Json?
  clerkId         String?
  walletCreditUsed Decimal? @default(0)
  orderId         String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── INVENTORY MODULE ─────────────────────────────────────────────────────────

enum StockLogType {
  SALE // Retail order
  RESTOCK // Manual addition
  RESERVATION // B2B reservation
  ADJUSTMENT // Manual correction
  RETURN // Order return
}

model StockLog {
  id        String  @id @default(cuid())
  variantId String
  variant   Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  type       StockLogType
  change     Int // Positive for additions, negative for reductions
  newBalance Int // The balance after this change

  referenceId String? // e.g. Order ID or Proforma ID
  notes       String?

  createdAt DateTime @default(now())
}

model StockReservation {
  id        String  @id @default(cuid())
  variantId String
  variant   Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  orderId        String? // Retail Order (if any, used during checkout timeout)
  proformaId     String? // Wholesale Order Proforma
  orderIntentId  String? // Gateway order ID (e.g. Razorpay order ID) — set during checkout

  quantity  Int
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


// ─── WEBHOOK QUEUE & DEAD LETTER ────────────────────────────────────────────

enum WebhookStatus {
  RECEIVED    // Just arrived — awaiting first processing attempt
  PROCESSING  // Currently being handled (prevents concurrent duplicate runs)
  SUCCESS     // Fully processed — immutable
  FAILED      // Processing failed — scheduled for retry
  DEAD        // Exceeded max retries — moved to Dead Letter Queue
}

model WebhookEvent {
  id        String        @id @default(cuid())
  gateway   String        // RAZORPAY | PHONEPE
  eventType String        // payment.captured | payment.failed | etc.
  status    WebhookStatus @default(RECEIVED)

  // Raw payload preserved for replay
  rawPayload  Json
  signature   String? // The gateway signature header value

  // Retry tracking
  attempts      Int       @default(0)
  maxAttempts   Int       @default(5)
  nextRetryAt   DateTime? // When to next attempt — set with exponential backoff
  lastError     String?   // Last error message — for debugging

  // DLQ metadata
  deadReason    String?   // Why this event was killed
  deadAt        DateTime? // When it was moved to DLQ

  // Linked order (once processed)
  orderId String?

  createdAt   DateTime @default(now())
  processedAt DateTime?

  @@index([status, nextRetryAt]) // Optimised for cron polling
  @@index([gateway, eventType])
}


enum InquiryStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
}

enum InquiryType {
  GENERAL
  ORDER_QUERY
  WHOLESALE
  COMPLAINT
}

model SupportInquiry {
  id      String  @id @default(cuid())
  name    String
  email   String
  phone   String?
  subject String
  message String

  type   InquiryType   @default(GENERAL)
  status InquiryStatus @default(PENDING)

  orderId String? // Optional link to order

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── NAVIGATION MODULE ────────────────────────────────────────────────────────

model Menu {
  id     String @id @default(cuid())
  name   String
  handle String @unique // e.g. "header-main", "footer-shop"

  items MenuItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MenuItem {
  id    String @id @default(cuid())
  label String
  url   String
  order Int    @default(0)

  menuId String
  menu   Menu   @relation(fields: [menuId], references: [id], onDelete: Cascade)

  parentId String?
  parent   MenuItem?  @relation("MenuSubItems", fields: [parentId], references: [id])
  children MenuItem[] @relation("MenuSubItems")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LeadStatus {
  PENDING
  NUDGE_1_SENT
  NUDGE_2_SENT
  CONVERTED
}

model CheckoutLead {
  id        String  @id @default(cuid())
  email     String?
  phone     String
  name      String?
  cartTotal Decimal
  items     Json? // Store cart items for personalization

  status LeadStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([phone, email])
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  content     String   @db.Text
  status      String   @default("DRAFT") // DRAFT, RUNNING, COMPLETED, FAILED
  metrics     Json?    // { totalSent: number, success: number, failed: number }
  
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── AI MODULE ───────────────────────────────────────────────────────────────

model AIStyleRule {
  id             String   @id @default(cuid())
  name           String
  trigger        String   @unique
  recommendation String   @db.Text
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── PROCUREMENT MODULE ───────────────────────────────────────────────────────

enum PurchaseStatus {
  PENDING
  ORDERED
  RECEIVED
  CANCELLED
}

model Supplier {
  id            String  @id @default(cuid())
  name          String
  contactPerson String?
  email         String?
  phone         String?
  gstNumber     String?
  address       String?
  category      String? // e.g. Silk, Cotton, Packaging

  purchaseOrders PurchaseOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PurchaseOrder {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  status      PurchaseStatus @default(PENDING)
  totalCost   Decimal
  autoRestock Boolean        @default(false)
  notes       String?

  items PurchaseOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  variantId String
  variant   Variant @relation(fields: [variantId], references: [id])

  quantity  Int
  costPrice Decimal
  gstRate   Decimal @default(5.00)
  hsnCode   String?
}

model Invoice {
  id             String   @id @default(cuid())
  invoiceNumber  String   @unique
  referenceId    String?
  referenceType  String?  // RETAIL, WHOLESALE
  
  customerName   String
  customerEmail  String
  customerPhone  String?
  
  date           DateTime @default(now())
  dueDate        DateTime?
  status         String   @default("DRAFT") // DRAFT, SENT, PAID, VOID
  
  subtotal       Decimal
  taxAmount      Decimal
  totalAmount    Decimal
  amountPaid     Decimal  @default(0)
  
  tableData      Json     // Array of items
  customFields   Json?    // Any extra metadata
  
  templateId     String?
  template       InvoiceTemplate? @relation(fields: [templateId], references: [id])
  
  signatureUrl   String?
  watermarkUrl   String?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model InvoiceTemplate {
  id           String    @id @default(cuid())
  name         String
  layout       String    // CLASSIC, MODERN, MINIMAL
  headerHtml   String?
  footerHtml   String?
  primaryColor String?
  
  invoices     Invoice[]
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum ReferralStatus {
  PENDING
  COMPLETED
  REWARDED
}

enum WalletTxType {
  CREDIT
  DEBIT
}

enum WalletTxReason {
  ORDER_PAYMENT
  REFUND
  REFERRAL_REWARD
  LOYALTY_REWARD
  MANUAL_ADJUSTMENT
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  balance   Decimal  @default(0)
  
  transactions WalletTransaction[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WalletTransaction {
  id       String   @id @default(cuid())
  walletId String
  wallet   Wallet   @relation(fields: [walletId], references: [id])
  
  amount   Decimal  // Positive for credit, negative for debit
  type     WalletTxType
  reason   WalletTxReason
  status   String   @default("COMPLETED")
  
  referenceId String? // Order ID, etc.
  notes       String?
  
  createdAt DateTime @default(now())
}

model Referral {
  id             String   @id @default(cuid())
  referrerId     String
  referrer       User     @relation("Referrer", fields: [referrerId], references: [id])
  
  refereeId      String   @unique
  referee        User     @relation("Referee", fields: [refereeId], references: [id])
  
  status         ReferralStatus @default(PENDING)
  rewardAmount   Decimal?
  orderId        String?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model OfferRule {
  id          String   @id @default(cuid())
  name        String
  description String?
  priority    Int      @default(0)
  isActive    Boolean  @default(true)
  
  conditions  Json     // e.g. { minCartValue: 1000, userType: 'new' }
  actions     Json     // e.g. { type: 'FREE_SHIPPING' }
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum ShipmentStatus {
  PENDING
  PACKED
  SHIPPED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RETURNED
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  PICKED
  RECEIVED
  REFUNDED
  REJECTED
}

model ShippingZone {
  id        String   @id @default(cuid())
  name      String   @unique
  regions   String[] // States or Countries
  isActive  Boolean  @default(true)
  methods   ShippingMethod[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShippingMethod {
  id             String   @id @default(cuid())
  zoneId         String
  zone           ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  name           String   // Standard, Express
  description    String?
  baseCost       Decimal  @default(0)
  minOrderValue  Decimal? // Minimum cart value for this method to be available
  maxOrderValue  Decimal? // Maximum cart value for this method to be available
  maxWeight      Decimal?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Courier {
  id           String   @id @default(cuid())
  name         String   @unique
  website      String?
  trackingUrl  String?  // Template URL with placeholder for ID
  isActive     Boolean  @default(true)
  shipments    Shipment[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Fulfillment {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  status    String   @default("PENDING") // PENDING, PROCESSING, FULFILLED
  items     FulfillmentItem[]
  shipments Shipment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FulfillmentItem {
  id            String   @id @default(cuid())
  fulfillmentId String
  fulfillment   Fulfillment @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)
  variantId     String
  quantity      Int
}

model Shipment {
  id               String   @id @default(cuid())
  fulfillmentId    String
  fulfillment      Fulfillment @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)
  courierId        String?
  courier          Courier? @relation(fields: [courierId], references: [id])
  trackingId       String?  @unique
  status           ShipmentStatus @default(PENDING)
  estimatedDelivery DateTime?
  shippedAt        DateTime?
  deliveredAt      DateTime?
  trackingHistory  Json?    // Array of events
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model OrderReturn {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  status      ReturnStatus @default(REQUESTED)
  reason      String
  notes       String?
  items       ReturnItem[]
  refundAmount Decimal?
  refundStatus String? // PENDING, COMPLETED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ReturnItem {
  id       String   @id @default(cuid())
  returnId String
  return   OrderReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  variantId String
  quantity  Int
}

model Otp {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

// ─── NOTIFICATIONS MODULE ─────────────────────────────────────────────────────

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String   @unique // e.g., "Order Confirmation"
  type      String   @unique // e.g., "ORDER_PLACED", "ORDER_SHIPPED", "RETURN_APPROVED"
  subject   String
  body      String   @db.Text
  isActive  Boolean  @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotificationLog {
  id        String   @id @default(cuid())
  type      String   // e.g., "ORDER_PLACED"
  channel   String   // e.g., "EMAIL", "WHATSAPP"
  recipient String   // email address or phone number
  status    String   @default("SENT") // SENT, FAILED, DELIVERED
  error     String?  @db.Text
  
  referenceId String? // e.g., Order ID
  
  createdAt DateTime @default(now())
}

model OrderActivity {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type      String   // STATUS_CHANGE, PAYMENT, NOTE, etc.
  message   String   @db.Text
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([orderId])
}

