{
  "name": "admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run css && next dev -p 6002 --webpack",
    "build": "npx tailwindcss -i ./src/app/globals.css -o ./public/compiled.css --minify || echo 'Tailwind skipped' && NODE_OPTIONS='--max-old-space-size=4096' next build --webpack && cp -r public .next/standalone/apps/admin/ 2>/dev/null || true && cp -r .next/static .next/standalone/apps/admin/.next/ 2>/dev/null || true",
    "css": "npx tailwindcss -i ./src/app/globals.css -o ./public/compiled.css --minify || echo 'Tailwind skipped'",
    "start": "next start -p 6010",
    "lint": "next lint"
  },
  "dependencies": {
    "clsx": "latest",
    "date-fns": "^4.2.1",
    "framer-motion": "latest",
    "lucide-react": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "recharts": "latest",
    "tailwind-merge": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "^10.4.0",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "latest"
  }
}
