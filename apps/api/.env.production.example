# ─────────────────────────────────────────────────────────
#  RAAGHAS API (NestJS) — .env.production
#  Copy this file to .env.production and fill in real values
#  NEVER commit .env.production to git
# ─────────────────────────────────────────────────────────

# App
PORT=6005
NODE_ENV=production
API_URL=https://api.rc.grafty.pro

# Allowed CORS Origins (comma-separated)
CORS_ORIGINS=https://rc.grafty.pro,https://admin.rc.grafty.pro

# Database (PostgreSQL)
DATABASE_URL=postgresql://raaghas_user:YOUR_DB_PASSWORD@localhost:5432/raaghas_db

# Clerk Authentication
CLERK_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLERK_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# JWT (if used alongside Clerk)
JWT_SECRET=your_super_secret_jwt_key_min_32_chars

# Payments (Razorpay / Stripe)
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Email (SendGrid / Resend)
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX
EMAIL_FROM=noreply@rc.grafty.pro

# Storage (if using S3 / Cloudflare R2)
S3_BUCKET_NAME=raaghas-uploads
S3_REGION=ap-south-1
S3_ACCESS_KEY=AKIAXXXXXXXXXXXXXXXX
S3_SECRET_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
S3_ENDPOINT=https://XXXX.r2.cloudflarestorage.com

# OpenAI (for AI features)
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
