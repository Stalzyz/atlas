{
  "name": "storefront",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run css && next dev -p 4401 --webpack",
    "build": "npm run css && NODE_OPTIONS='--max-old-space-size=4096' next build --webpack && cp -r public .next/standalone/apps/storefront/public",
    "css": "tailwindcss -i ./src/app/globals.css -o ./public/compiled.css --minify || true",
    "start": "next start -p 7009",
    "lint": "next lint"
  },
  "dependencies": {
    "@react-oauth/google": "^0.13.5",
    "clsx": "latest",
    "firebase": "^12.16.0",
    "framer-motion": "latest",
    "html2canvas": "^1.4.1",
    "js-cookie": "^3.0.5",
    "jspdf": "^4.2.1",
    "lucide-react": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "recharts": "^3.9.2",
    "tailwind-merge": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "^10.4.19",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "latest"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
