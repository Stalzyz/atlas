# Copy this to /scripts/.env.backup on the server and fill in values.
# This file is gitignored — never commit the real .env.backup.

# PostgreSQL connection (copy from apps/api/.env)
DATABASE_URL=postgresql://raaghas_user:Raaghas%40Prod2024@localhost:5432/raaghas

# Where to save backup archives
BACKUP_DIR=/backups/db          # for backup-db.sh
# BACKUP_DIR=/backups/files     # for backup-files.sh (override per script or use separate copies)

# Where uploads live on the server
UPLOAD_DIR=/var/www/atlas/apps/api/uploads

# Optional extra directories to include in file backup (space-separated)
# EXTRA_BACKUP_DIRS=/var/www/atlas/assets /var/www/atlas/invoices

# Log file path (shared by both scripts)
LOG_FILE=/backups/logs/backup.log

# NestJS API base URL (for failure notifications)
API_URL=http://localhost:6005

# Shared secret for the /backup/notify endpoint (set the same value in API .env as BACKUP_API_SECRET)
BACKUP_API_SECRET=change-me-to-a-random-secret
